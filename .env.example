# Firebase Web Config (public-safe, exposed to browser via Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional app id used in Firestore paths
VITE_APP_ID=carbon-planet-app

# Server-side only (set in Vercel Project Settings -> Environment Variables)
OPENAI_API_KEY=
# Optional. Default: https://api.openai.com/v1
OPENAI_BASE_URL=
# Optional. Default: gpt-4o-mini
OPENAI_MODEL=
OPENAI_VERIFY_MODEL=

# Image generation
# Option A (default): Use OpenAI Images API by setting OPENAI_IMAGE_MODEL + (optional) OPENAI_BASE_URL
# Option B (chat-based image gen, "solution 3"): point OPENAI_IMAGE_ENDPOINT to a chat completions URL
#   e.g. https://daniel522api.zeabur.app/v1/chat/completions
# and set OPENAI_IMAGE_MODEL to a model that returns a data URL (e.g. gemini-2.5-flash-image)
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_ENDPOINT=

# Google AI (Imagen/Gemini) - server-side only
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
